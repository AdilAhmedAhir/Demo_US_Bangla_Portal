{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git rev-parse*)",
      "Bash(git show*)",
      "Bash(ls*)",
      "Bash(cat docs/*)",
      "Bash(grep*)",
      "Bash(find docs*)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(php --version)",
      "Bash(python --version)",
      "Bash(go version)",
      "Bash(cargo --version)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf .*)",
      "Bash(cat .env)",
      "Bash(cat .env.*)"
    ]
  }
}
